# Logo công ty — dùng cho print page
# Có thể là:
#   Google Drive share link: https://drive.google.com/file/d/FILE_ID/view?usp=sharing
#   Hoặc direct image URL:   https://i.imgur.com/abc.png
# Nếu bỏ trống → hiển thị text "HP Jewelry" thay thế
NEXT_PUBLIC_LOGO_URL=

# Supabase — lấy từ Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service Role — NEVER expose to client, NEVER commit to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
